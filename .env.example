# ── ClearMark .env.example ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All settings have sane defaults for local development.

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Storage  ("local" or "s3") ────────────────────────────────────────────────
STORAGE_BACKEND=local

# AWS S3 — only required when STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=clearmark-files
S3_PRESIGN_EXPIRY=86400

# ── File lifecycle ────────────────────────────────────────────────────────────
FILE_TTL_SECONDS=86400        # 24 hours

# ── Processing limits ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
RASTERISE_DPI=300
AI_BATCH_PAGES=4              # pages per batch in AI track (OOM guard)
OPACITY_THRESHOLD=0.85        # alpha below this = suspect watermark
REPEAT_PAGE_THRESHOLD=0.5     # object on >50% of pages = watermark

# ── AI Inpainting ─────────────────────────────────────────────────────────────
USE_AI_INPAINTING=false       # set true to enable LaMa model
LAMA_MODEL_PATH=./models/lama # path to LaMa checkpoint directory
INPAINTING_API_URL=           # optional: external inpainting API endpoint

# ── Celery Flower (monitoring) ────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=clearmark
